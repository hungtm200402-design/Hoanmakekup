{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Beauty API Auto",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\run-backend.ps1"
      ],
      "isBackground": true,
      "problemMatcher": [],
      "runOptions": {
        "runOn": "folderOpen"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": false
      }
    },
    {
      "label": "Beauty Frontend Auto",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\run-frontend.ps1"
      ],
      "isBackground": true,
      "problemMatcher": [],
      "runOptions": {
        "runOn": "folderOpen"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": false
      }
    },
    {
      "label": "Beauty Full Auto",
      "dependsOn": [
        "Beauty API Auto",
        "Beauty Frontend Auto"
      ],
      "problemMatcher": [],
      "runOptions": {
        "reevaluateOnRerun": true
      }
    }
  ]
}
