{
  "manifest_version": 3,
  "name": "Lưu sản phẩm vào Hoàn Doãn",
  "version": "1.0.0",
  "description": "Lưu trang sản phẩm trusted website vào kho SOURCE CAPTURE của Hoàn Doãn.",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": ["http://127.0.0.1:5000/*", "http://localhost:5000/*"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Lưu vào Hoàn Doãn"
  }
}
